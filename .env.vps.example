# ==================== CONFIGURACIÓN VPS (Producción) ====================
# Copia estas variables a tu archivo .env en la VPS
# Reemplaza TU_IP_PUBLICA con la IP real de tu VPS

# Evolution API Configuration
USE_EVOLUTION_API=true
EVOLUTION_API_URL=http://72.62.165.89:8080
EVOLUTION_API_KEY=1234
BACKEND_URL=http://72.62.165.89:4000

# NOTA CRÍTICA:
# - EVOLUTION_API_URL debe usar la IP pública, NO 127.0.0.1 ni localhost
# - BACKEND_URL es necesaria para que los webhooks funcionen
# - Si tu IP es diferente, reemplaza 72.62.165.89 con tu IP real

# ==================== CAMBIOS REQUERIDOS EN TU .env ====================
# Cambia esta línea:
# EVOLUTION_API_URL=http://127.0.0.1:8080  ❌ INCORRECTO
# Por esta:
# EVOLUTION_API_URL=http://72.62.165.89:8080  ✅ CORRECTO

# Y agrega esta línea si no existe:
# BACKEND_URL=http://72.62.165.89:4000

# ==================== INSTRUCCIONES ====================
# 1. En la VPS, edita el archivo .env del backend
# 2. Cambia EVOLUTION_API_URL de 127.0.0.1:8080 a 72.62.165.89:8080
# 3. Agrega BACKEND_URL=http://72.62.165.89:4000
# 4. Reinicia el backend: pm2 restart backend
# 5. Reinicia docker-compose: docker-compose down && docker-compose up -d
